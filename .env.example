PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/craftech?retryWrites=true&w=majority

# JWT (minimum 32 characters)
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_chars
JWT_EXPIRES_IN=7d

# Cloudinary (image/video storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP (email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=info@craftechengineers.com

# Admin Seed (used only for initial setup via npm run seed)
ADMIN_EMAIL=admin@craftechengineers.com
ADMIN_PASSWORD=CraftechAdmin@2024
ADMIN_NAME=Craftech Admin

# CORS
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
